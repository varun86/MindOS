{
  "manifest_version": 3,
  "name": "MindOS Web Clipper",
  "version": "0.1.6",
  "description": "Save web pages and AI chat sessions to your MindOS Inbox — one click, clean Markdown.",
  "icons": {
    "16": "icons/icon-16.svg",
    "32": "icons/icon-32.svg",
    "48": "icons/icon-48.svg",
    "128": "icons/icon-128.svg"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.svg",
      "32": "icons/icon-32.svg"
    },
    "default_title": "Clip to MindOS"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "http://localhost:*/*",
    "http://127.0.0.1:*/*",
    "http://[::1]:*/*",
    "http://10.*.*.*:*/*",
    "http://172.16.*.*:*/*",
    "http://192.168.*.*:*/*"
  ],
  "commands": {
    "clip-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+M",
        "mac": "Command+Shift+M"
      },
      "description": "Clip current page to MindOS"
    }
  }
}
