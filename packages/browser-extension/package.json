{
  "name": "@mindos/browser-extension",
  "version": "0.1.6",
  "private": true,
  "description": "MindOS Web Clipper — save any web page to your knowledge base",
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "clean": "node scripts/clean-extension.mjs",
    "type-check": "tsc --noEmit",
    "package": "pnpm run build && node scripts/package-extension.mjs"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.39",
    "@types/turndown": "^5.0.6",
    "archiver": "^7.0.1",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
