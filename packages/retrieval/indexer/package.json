{
  "name": "@mindos/indexer",
  "version": "1.0.0",
  "description": "File indexing service for MindOS",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@mindos/search": "workspace:*",
    "@mindos/vector": "workspace:*",
    "chokidar": "^4.0.3",
    "@geminilight/mindos": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
