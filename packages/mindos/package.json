  "files": [
    "bin/mindos-shim.cjs",
    "dist/",
    "src/cli.js",
    "src/cli.d.ts",
    "README.md",
    "README_zh.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "prepack": "cd ../.. && node scripts/clean-product-stage.mjs --include-package-docs --keep-standalone && pnpm --filter @geminilight/mindos build && node scripts/stage-product-package.mjs",
    "postpack": "cd ../.. && node scripts/clean-product-stage.mjs --include-package-docs",
    "type-check": "tsc --noEmit",
    "test": "vitest run --dir src",
    "test:watch": "vitest",
    "build": "tsc && node ../../scripts/copy-mindos-agent-assets.mjs && pnpm run build:protocols",
    "build:protocols": "node ../../scripts/build-product-protocols.mjs",
    "build:platform-packages": "node ../../scripts/build-platform-packages.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sinclair/typebox": "^0.34.33",
    "chokidar": "^4.0.3",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@geminilight/mindos-darwin-arm64": "1.1.31",
    "@geminilight/mindos-darwin-x64": "1.1.31",
    "@geminilight/mindos-linux-arm64": "1.1.31",
    "@geminilight/mindos-linux-arm64-musl": "1.1.31",
    "@geminilight/mindos-linux-x64": "1.1.31",
    "@geminilight/mindos-linux-x64-musl": "1.1.31",
    "@geminilight/mindos-windows-arm64": "1.1.31",
    "@geminilight/mindos-windows-x64": "1.1.31"
  },
  "devDependencies": {
    "@agentclientprotocol/sdk": "^0.18.2",
    "@anthropic-ai/claude-agent-sdk": "0.3.170",
    "@earendil-works/pi-agent-core": "0.78.1",
    "@earendil-works/pi-coding-agent": "0.78.1",
    "@types/node": "^22.10.5",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
