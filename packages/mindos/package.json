      "types": "./dist/agent/mindos-pi/extension/*.d.ts",
      "import": "./dist/agent/mindos-pi/extension/*.js"
    },
    "./agent/mindos-pi/*": {
      "types": "./dist/agent/mindos-pi/*.d.ts",
      "import": "./dist/agent/mindos-pi/*.js"
    },
    "./agent/pi": {
      "types": "./dist/agent/pi/index.d.ts",
      "import": "./dist/agent/pi/index.js"
