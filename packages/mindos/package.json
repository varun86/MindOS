    "./agent/tool/*": {
      "types": "./dist/agent/tool/*.d.ts",
      "import": "./dist/agent/tool/*.js"
    },
    "./agent/*": {
      "types": "./dist/agent/*.d.ts",
      "import": "./dist/agent/*.js"
    },
    "./agent-runtime": {
      "types": "./dist/agent-runtime.d.ts",
      "import": "./dist/agent-runtime.js"
    },
    "./agent-runtime/adapters": {
      "types": "./dist/agent-runtime/adapters/index.d.ts",
      "import": "./dist/agent-runtime/adapters/index.js"
    },
    "./agent-runtime/adapters/*": {
      "types": "./dist/agent-runtime/adapters/*.d.ts",
      "import": "./dist/agent-runtime/adapters/*.js"
    },
    "./agent-runtime/runtime-env": {
      "types": "./dist/agent-runtime/runtime-env.d.ts",
      "import": "./dist/agent-runtime/runtime-env.js"
    },
    "./foundation": {
      "types": "./dist/foundation.d.ts",
      "import": "./dist/foundation.js"
    },
    "./knowledge": {
      "types": "./dist/knowledge.d.ts",
